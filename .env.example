# ==============================================================================
# CONFIGURAÇÕES DE DOMÍNIO E REDE DO SERVIDOR DE E-MAIL
# ==============================================================================
MAIL_DOMAIN=jurixis.com.br
MAIL_HOSTNAME=mail.jurixis.com.br
TZ=America/Sao_Paulo

# ==============================================================================
# CONTAS ADMINISTRATIVAS PADRÃO (CRIADAS NO BOOTSTRAP)
# ==============================================================================
# E-mail do postmaster e administrador inicial
ADMIN_EMAIL=admin@jurixis.com.br
POSTMASTER_EMAIL=postmaster@jurixis.com.br

# Senha administrativa inicial para o painel e servidor de e-mail (MÍNIMO 8 CARACTERES)
ADMIN_PASSWORD=admin-secure-password-2026

# ==============================================================================
# CONFIGURAÇÕES DE SEGURANÇA E ANTISPAM
# ==============================================================================
# Seletor DKIM usado no registro DNS TXT (ex: mail._domainkey.jurixis.com.br)
DKIM_SELECTOR=mail
ENABLE_RSPAMD=true
ENABLE_GREYLIST=false

# ==============================================================================
# PAINEL ADMINISTRATIVO (jx-mail-panel)
# ==============================================================================
# Porta exposta para acesso ao painel de administração web
PANEL_PORT=3003

# Chave secreta para assinar os tokens JWT locais do painel
JWT_SECRET=super-secret-jwt-token-key-2026

# Integração Keycloak (Opcional - caso queira unificar com o jx-auth)
KEYCLOAK_BASE_URL=https://auth.jurixis.com.br
KEYCLOAK_REALM=jurixis
KEYCLOAK_CLIENT_ID=jx-mail-panel

# ==============================================================================
# DIRETÓRIOS E CERTIFICADOS TLS
# ==============================================================================
# Caminhos absolutos para certificados TLS/SSL no host VPS (ex: gerados pelo Caddy ou Let's Encrypt)
# Deixe em branco se desejar que o Stalwart gere certificados autoassinados para testes locais
TLS_CERT_PATH=/etc/letsencrypt/live/mail.jurixis.com.br/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/mail.jurixis.com.br/privkey.pem
